NODE_ENV=production
PORT=4000

# PostgreSQL
DATABASE_URL=postgresql://digygo_user:digygo123@localhost:5432/digygocrm

# Auth
JWT_SECRET=replace_with_strong_random_string_min_32_chars
JWT_EXPIRES_IN=15m
ENCRYPTION_KEY=replace_with_exactly_32_char_string

# Redis — when set, rate limiting, IP-block strikes, and caches are Redis-backed
# (persist across restarts + hold across instances). Unset = in-memory fallback.
REDIS_URL=redis://127.0.0.1:6379

# Domain — set to your Hostinger domain
FRONTEND_URL=https://yourdomain.com
WEBHOOK_BASE_URL=https://yourdomain.com

# Meta / Facebook
META_APP_ID=
META_APP_SECRET=
# WhatsApp Embedded Signup configuration ID (Meta dashboard → WhatsApp → Embedded Signup).
# Required for customers to self-connect their own WhatsApp number via "Connect with Facebook".
META_CONFIG_ID=
META_WEBHOOK_VERIFY_TOKEN=d7dde81a60c0867e0866cdb073538ce8
META_API_VERSION=v21.0

# WhatsApp Business Cloud API (WABA) — global fallback account.
# Used for tenants that have not connected their own number under Integrations → WhatsApp.
# Get these from Meta Business Manager → WhatsApp → API Setup.
WABA_PHONE_NUMBER_ID=
WABA_ID=
WABA_ACCESS_TOKEN=
WABA_PHONE_NUMBER=

# Dialer mobile-number OTP over WhatsApp.
# WABA_OTP_TEMPLATE: name of an APPROVED WhatsApp "authentication" template that
#   takes the code as its body variable {{1}} (and a copy-code/autofill button).
#   Leave blank to fall back to a plain text message (only delivers inside the 24h
#   conversation window — fine for testing, not for fresh numbers).
# WABA_OTP_TEMPLATE_LANG: the template's language code (e.g. en_US, en).
# WABA_OTP_TEMPLATE_HAS_BUTTON: 'false' if your template has no copy-code button.
WABA_OTP_TEMPLATE=
WABA_OTP_TEMPLATE_LANG=en_US
WABA_OTP_TEMPLATE_HAS_BUTTON=true

# SMTP (optional — for email automation actions)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=DigyGo CRM
SMTP_FROM_EMAIL=
